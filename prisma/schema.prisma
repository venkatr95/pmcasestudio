generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  caseStudies   CaseStudy[]
  preferences   UserPreferences?
  exports       Export[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  theme         String   @default("aurora")
  mode          String   @default("detailed")
  aiAssistance  Boolean  @default(true)
  autoSave      Boolean  @default(true)
  productType   String?
  studyStyle    String?
  onboarded     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CaseStudy {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?
  productType   String    @default("digital")
  studyStyle    String    @default("executive")
  theme         String    @default("aurora")
  status        String    @default("draft")
  currentPhase  Int       @default(1)
  progress      Int       @default(0)
  templateId    String?
  coverImage    String?
  tags          String    @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases        PhaseData[]
  deliverables  Deliverable[]
  exports       Export[]
  template      Template? @relation(fields: [templateId], references: [id])
}

model PhaseData {
  id          String   @id @default(cuid())
  caseStudyId String
  phase       Int
  data        String   @default("{}")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@unique([caseStudyId, phase])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  category    String
  featured    Boolean  @default(false)
  builtIn     Boolean  @default(false)
  thumbnail   String?
  data        String   @default("{}")
  tags        String   @default("[]")
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseStudies CaseStudy[]
}

model Deliverable {
  id          String   @id @default(cuid())
  caseStudyId String
  type        String
  title       String
  content     String?
  url         String?
  size        Int?
  createdAt   DateTime @default(now())

  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
}

model Export {
  id          String   @id @default(cuid())
  userId      String
  caseStudyId String
  format      String
  status      String   @default("pending")
  url         String?
  error       String?
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
}
